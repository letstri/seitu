{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", ".output/**"]
    },
    "test": {},
    "check-types": {},
    "lint": {},
    "dev": {
      "cache": false,
      "persistent": true
    },
    "docs:generate": {
      "outputs": [".source/**"]
    }
  }
}
