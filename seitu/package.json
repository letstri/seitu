{
  "name": "seitu",
  "displayName": "Seitu",
  "type": "module",
  "version": "0.16.1",
  "private": false,
  "packageManager": "pnpm@11.9.0",
  "author": "Valerii Strilets",
  "license": "MIT",
  "funding": "https://github.com/sponsors/letstri",
  "homepage": "https://seitu.letstri.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/letstri/seitu.git",
    "directory": "seitu"
  },
  "bugs": {
    "url": "https://github.com/letstri/seitu/issues"
  },
  "keywords": [
    "typescript",
    "react",
    "vue",
    "solid",
    "solid-js",
    "svelte",
    "utils",
    "type-safe",
    "tanstack-intent"
  ],
  "intent": {
    "repo": "letstri/seitu",
    "docs": "../docs/content/docs"
  },
  "exports": {
    ".": {
      "types": "./dist/core/index.d.mts",
      "import": "./dist/core.mjs"
    },
    "./web": {
      "types": "./dist/web/index.d.mts",
      "import": "./dist/web.mjs"
    },
    "./react": {
      "types": "./dist/react/index.d.mts",
      "import": "./dist/react.mjs"
    },
    "./vue": {
      "types": "./dist/vue/index.d.mts",
      "import": "./dist/vue.mjs"
    },
    "./solid": {
      "types": "./dist/solid/index.d.mts",
      "import": "./dist/solid.mjs"
    },
    "./svelte": {
      "types": "./dist/svelte/index.d.mts",
      "import": "./dist/svelte.mjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.mts",
      "import": "./dist/utils.mjs"
    }
  },
  "main": "./dist/core.mjs",
  "types": "./dist/core/index.d.mts",
  "files": [
    "dist",
    "skills"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepublishOnly": "run-s check-types test build scripts:copy-readme skills:validate",
    "build": "tsdown",
    "test": "vitest run",
    "check-types": "tsc",
    "scripts:copy-readme": "node ./scripts/copy-readme.ts",
    "skills:validate": "intent validate skills",
    "skills:stale": "intent stale skills"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19",
    "solid-js": ">=1.9",
    "svelte": ">=5",
    "vue": ">=3.5"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "dependencies": {
    "fast-equals": "^6.0.0"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@standard-schema/spec": "^1.1.0",
    "@tanstack/intent": "^0.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@vitejs/plugin-react": "^6.0.3",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.10.6",
    "react-dom": "^19.2.7",
    "solid-js": "^1.9.13",
    "svelte": "^5.56.4",
    "tsdown": "^0.22.3",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.9",
    "vue": "^3.5.39",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
