{
  "name": "seitu",
  "displayName": "Seitu",
  "type": "module",
  "version": "0.15.0",
  "private": false,
  "packageManager": "pnpm@11.5.3",
  "author": "Valerii Strilets",
  "license": "MIT",
  "funding": "https://github.com/sponsors/letstri",
  "homepage": "https://seitu.letstri.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/letstri/seitu.git",
    "directory": "seitu"
  },
  "bugs": {
    "url": "https://github.com/letstri/seitu/issues"
  },
  "keywords": [
    "typescript",
    "react",
    "vue",
    "utils",
    "type-safe"
  ],
  "exports": {
    ".": {
      "types": "./dist/core/index.d.mts",
      "import": "./dist/core.mjs"
    },
    "./web": {
      "types": "./dist/web/index.d.mts",
      "import": "./dist/web.mjs"
    },
    "./react": {
      "types": "./dist/react/index.d.mts",
      "import": "./dist/react.mjs"
    },
    "./vue": {
      "types": "./dist/vue/index.d.mts",
      "import": "./dist/vue.mjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.mts",
      "import": "./dist/utils.mjs"
    }
  },
  "main": "./dist/core.mjs",
  "types": "./dist/core/index.d.mts",
  "files": [
    "dist",
    "skills"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepublishOnly": "run-s check-types test build scripts:copy-readme scripts:copy-skills",
    "build": "tsdown",
    "test": "vitest run",
    "check-types": "tsc",
    "scripts:copy-readme": "node ./scripts/copy-readme.ts",
    "scripts:copy-skills": "node ./scripts/copy-skills.ts"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19",
    "vue": ">=3.5"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "dependencies": {
    "fast-equals": "^6.0.0"
  },
  "devDependencies": {
    "@standard-schema/spec": "^1.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.10.2",
    "react-dom": "^19.2.7",
    "tsdown": "^0.22.2",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3",
    "vite": "^6.4.3",
    "vitest": "^3.2.6",
    "vue": "^3.5.35",
    "zod": "^4.4.3"
  }
}
