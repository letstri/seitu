{
  "name": "docs",
  "type": "module",
  "private": true,
  "sideEffects": false,
  "scripts": {
    "prebuild": "pnpm run docs:generate && cd ../seitu && pnpm run build",
    "dev": "vite dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "preview": "vite preview",
    "docs:generate": "node scripts/generate-docs.ts",
